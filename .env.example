# ===================================================================
# VerimutFS Node Configuration
# ===================================================================

# -------------------------------------------------------------------
# HTTP API Configuration
# -------------------------------------------------------------------
API_PORT=3001

# -------------------------------------------------------------------
# VNS Bootstrap Discovery (Pure VNS - No IP Sharing!)
# -------------------------------------------------------------------

# For GENESIS/BOOTSTRAP nodes:
# Set your public URL so others can reach you
# This gets registered as "bootstrap-node.vfs" in VNS
BOOTSTRAP_PUBLIC_URL=http://your-public-ip:3001

# For REGULAR PEERS:
# Just use "bootstrap-node" - VNS resolves it automatically!
# No IPs needed, pure decentralized discovery
HTTP_BOOTSTRAP_PEERS=bootstrap-node

# First-time seed (only needed if you're NOT the genesis)
# Point to ANY bootstrap to query VNS and discover the network
# After first connection, VNS handles everything
SEED_BOOTSTRAP=http://some-bootstrap-ip:3001

# -------------------------------------------------------------------
# VNS Configuration
# -------------------------------------------------------------------
ENABLE_VNS=true

# -------------------------------------------------------------------
# Storage & Logging
# -------------------------------------------------------------------
DATA_DIR=./verimut-data
VERBOSE=false

# -------------------------------------------------------------------
# Legacy P2P (optional, HTTP P2P is primary)
# -------------------------------------------------------------------
LISTEN_PORT=0
BOOTSTRAP_PEERS=
